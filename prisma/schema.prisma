generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}

enum UserRole {
  ADMIN
  AGENT
}

enum TransactionType {
  EARN
  WITHDRAW
  REFUND
}

enum TransactionStatus {
  PENDING
  COMPLETED
  REJECTED
}

enum SaleStatus {
  SUCCESS
  CANCELLED
}

model City {
  id         Int        @id @default(autoincrement())
  adi        String?    @db.VarChar(255)
  districts  District[]
  customers  Customer[]

  @@map("iller")
}

model District {
  id         Int        @id @default(autoincrement())
  adi        String?    @db.VarChar(255)
  il_id      Int?
  city       City?      @relation(fields: [il_id], references: [id], onDelete: Cascade)
  customers  Customer[]

  @@map("ilceler")
}

model Neighborhood {
  id         Int        @id @default(autoincrement())
  adi        String?    @db.VarChar(255)
  ilce_id    Int?
  il_id      Int?       // Veri kaybını önlemek için eklendi

  @@map("mahalleler")
}

model Street {
  id         Int        @id @default(autoincrement())
  adi        String?    @db.VarChar(255)
  mahalle_id Int?
  ilce_id    Int?       // Veri kaybını önlemek için eklendi
  il_id      Int?       // Veri kaybını önlemek için eklendi

  @@map("yollar")
}

model User {
  id            String   @id @default(uuid()) @db.Char(36)
  tc_no         String   @unique
  bayiKodu      String?  @unique @db.VarChar(4)
  first_name    String
  last_name     String
  sirketAdi     String?
  phone         String
  email         String   @unique
  password_hash String
  role          UserRole
  is_active     Boolean  @default(true)
  created_at    DateTime @default(now())
  updated_at    DateTime @updatedAt

  // Optional mirrored balance field for reporting
  balance       Float    @default(0)

  wallet    Wallet?
  policies Sale[]
  customers Customer[]
}

model Customer {
  id             String   @id @default(uuid()) @db.Char(36)
  agent_id       String   @db.Char(36)
  full_name      String
  tc_no          String
  phone          String
  created_at     DateTime @default(now())

  // New CRM-friendly fields
  type           String   @default("Bireysel")
  name           String
  identityNumber String
  createdAt      DateTime @default(now())

  cityId     Int?      @map("city_id")
  districtId Int?      @map("district_id")
  city       City?     @relation(fields: [cityId], references: [id])
  district   District? @relation(fields: [districtId], references: [id])

  agent    User     @relation(fields: [agent_id], references: [id])
  vehicles Vehicle[]

  @@unique([agent_id, tc_no])
}

model Vehicle {
  id              String   @id @default(uuid()) @db.Char(36)
  customer_id     String   @db.Char(36)
  plate_number    String
  document_serial String?
  brand           String
  model           String
  year            Int
  usage_type      String
  created_at      DateTime @default(now())

  customer Customer @relation(fields: [customer_id], references: [id])
}

model Wallet {
  id         String   @id @default(uuid()) @db.Char(36)
  user_id    String   @unique @db.Char(36)
  balance    Float    @default(0)
  created_at DateTime @default(now())
  updated_at DateTime @updatedAt

  user         User          @relation(fields: [user_id], references: [id])
  transactions Transaction[]
}

model Transaction {
  id             String            @id @default(uuid()) @db.Char(36)
  wallet_id      String            @db.Char(36)
  type           TransactionType
  amount         Float
  status         TransactionStatus
  description    String
  balance_before Float?
  balance_after  Float?
  created_at     DateTime         @default(now())

  wallet Wallet @relation(fields: [wallet_id], references: [id])
}

model Package {
  id                 String   @id @default(uuid()) @db.Char(36)
  name               String
  limits_description String
  base_price         Float
  commission_amount  Float
  // New dynamic pricing fields
  price              Float   @default(0)
  commission         Float   @default(0)
  is_active          Boolean  @default(true)
  created_at         DateTime @default(now())

  totalLimit        String
  breakdownLimit    String
  accidentLimit     String
  towingLimit       String
  replacementCar    String?
  serviceType       String   @default("EN YAKIN TAMİRHANE")
  ageLimit          String   @default("Yaş sınırı yoktur")
  compatibleVehicles String

  sales Sale[]
}

model Sale {
  id                  String     @id @default(uuid()) @db.Char(36)
  agent_id            String     @db.Char(36)
  package_id          String     @db.Char(36)
  customer_tc         String
  customer_first_name String
  customer_last_name  String
  customer_plate      String
  car_brand_model     String
  sale_price          Float
  commission_earned   Float
  status              SaleStatus
  created_at          DateTime @default(now())

  // Coverage period
  startDate           DateTime @default(now())
  endDate             DateTime?
  durationDays        Int      @default(365)

  /// KDV / prim snapshot at sale time (historical accuracy)
  kdvRate             Float    @default(20)
  netPrice            Float?
  kdvAmount           Float?

  /// Sözleşme / Poliçe numarası
  policyNumber        String   @unique @default(cuid())
  sozlesmeNo          String?  @unique

  plaka String?
  marka String?
  model String?
  modelYili Int?
  kullanimTarzi String?
  netPrim Float?
  kdv Float? @default(20)
  brutPrim Float?
  il_id Int?
  ilce_id Int?
  tcVkn String?
  telefon String?
  acikAdres String?

  agent   User    @relation(fields: [agent_id], references: [id])
  package Package @relation(fields: [package_id], references: [id])
}

